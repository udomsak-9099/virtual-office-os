# Database
DATABASE_URL=postgresql://vos:vos_dev@localhost:5432/virtual_office_os
DATABASE_URL_TEST=postgresql://vos:vos_dev@localhost:5432/virtual_office_os_test

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# AI
AI_PROVIDER=anthropic
AI_API_KEY=your-api-key-here
AI_DEFAULT_MODEL=claude-sonnet-4-6

# Storage (S3-compatible)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=vos-files

# Search (OpenSearch)
OPENSEARCH_URL=http://localhost:9200

# App
APP_PORT=3001
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NODE_ENV=development
